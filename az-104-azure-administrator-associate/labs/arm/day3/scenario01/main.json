{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "northeurope"
    },
    "storageAccountName": {
      "type": "string"
    },
    "lifecycleCoolAfterDays": {
      "type": "int",
      "defaultValue": 30
    },
    "lifecycleDeleteAfterDays": {
      "type": "int",
      "defaultValue": 365
    }
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[parameters('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false,
        "supportsHttpsTrafficOnly": true
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/managementPolicies",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/default', parameters('storageAccountName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]"
      ],
      "properties": {
        "policy": {
          "rules": [
            {
              "enabled": true,
              "name": "moveToCoolAndDelete",
              "type": "Lifecycle",
              "definition": {
                "filters": {
                  "blobTypes": [
                    "blockBlob"
                  ],
                  "prefixMatch": [
                    "lab/"
                  ]
                },
                "actions": {
                  "baseBlob": {
                    "tierToCool": {
                      "daysAfterModificationGreaterThan": "[parameters('lifecycleCoolAfterDays')]"
                    },
                    "delete": {
                      "daysAfterModificationGreaterThan": "[parameters('lifecycleDeleteAfterDays')]"
                    }
                  }
                }
              }
            }
          ]
        }
      }
    }
  ],
  "outputs": {
    "scenario": {
      "type": "string",
      "value": "day3-scenario01"
    },
    "storageName": {
      "type": "string",
      "value": "[parameters('storageAccountName')]"
    }
  }
}
