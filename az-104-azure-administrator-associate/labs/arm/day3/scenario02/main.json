{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "northeurope"
    },
    "storageAccountName": {
      "type": "string"
    },
    "fileShareName": {
      "type": "string",
      "defaultValue": "fileshare01"
    },
    "shareQuotaGiB": {
      "type": "int",
      "defaultValue": 100
    }
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[parameters('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "minimumTlsVersion": "TLS1_2",
        "supportsHttpsTrafficOnly": true
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/fileServices",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/default', parameters('storageAccountName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/fileServices/shares",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/default/{1}', parameters('storageAccountName'), parameters('fileShareName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/fileServices', parameters('storageAccountName'), 'default')]"
      ],
      "properties": {
        "shareQuota": "[parameters('shareQuotaGiB')]",
        "enabledProtocols": "SMB"
      }
    }
  ],
  "outputs": {
    "scenario": {
      "type": "string",
      "value": "day3-scenario02"
    },
    "storageName": {
      "type": "string",
      "value": "[parameters('storageAccountName')]"
    },
    "deployedShareName": {
      "type": "string",
      "value": "[parameters('fileShareName')]"
    }
  }
}
