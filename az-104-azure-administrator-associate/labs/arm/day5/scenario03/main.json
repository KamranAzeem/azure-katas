{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "northeurope"
    },
    "cleanupTagValue": {
      "type": "string",
      "defaultValue": "true"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Resources/tags",
      "apiVersion": "2021-04-01",
      "name": "default",
      "properties": {
        "tags": {
          "CleanupCandidate": "[parameters('cleanupTagValue')]"
        }
      }
    }
  ],
  "outputs": {
    "scenario": {
      "type": "string",
      "value": "day5-scenario03"
    },
    "cleanupTagApplied": {
      "type": "string",
      "value": "[parameters('cleanupTagValue')]"
    }
  }
}
