{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "northeurope"
    },
    "publicIpName": {
      "type": "string",
      "defaultValue": "pip-az104-d2-lb"
    },
    "loadBalancerName": {
      "type": "string",
      "defaultValue": "lb-az104-d2"
    },
    "frontendName": {
      "type": "string",
      "defaultValue": "fe-01"
    },
    "backendPoolName": {
      "type": "string",
      "defaultValue": "be-01"
    },
    "probeName": {
      "type": "string",
      "defaultValue": "tcp-80-probe"
    },
    "ruleName": {
      "type": "string",
      "defaultValue": "tcp-80-rule"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-11-01",
      "name": "[parameters('publicIpName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static"
      }
    },
    {
      "type": "Microsoft.Network/loadBalancers",
      "apiVersion": "2023-11-01",
      "name": "[parameters('loadBalancerName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/publicIPAddresses', parameters('publicIpName'))]"
      ],
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "frontendIPConfigurations": [
          {
            "name": "[parameters('frontendName')]",
            "properties": {
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', parameters('publicIpName'))]"
              }
            }
          }
        ],
        "backendAddressPools": [
          {
            "name": "[parameters('backendPoolName')]"
          }
        ],
        "probes": [
          {
            "name": "[parameters('probeName')]",
            "properties": {
              "protocol": "Tcp",
              "port": 80,
              "intervalInSeconds": 5,
              "numberOfProbes": 2
            }
          }
        ],
        "loadBalancingRules": [
          {
            "name": "[parameters('ruleName')]",
            "properties": {
              "protocol": "Tcp",
              "frontendPort": 80,
              "backendPort": 80,
              "enableFloatingIP": false,
              "idleTimeoutInMinutes": 4,
              "frontendIPConfiguration": {
                "id": "[resourceId('Microsoft.Network/loadBalancers/frontendIPConfigurations', parameters('loadBalancerName'), parameters('frontendName'))]"
              },
              "backendAddressPool": {
                "id": "[resourceId('Microsoft.Network/loadBalancers/backendAddressPools', parameters('loadBalancerName'), parameters('backendPoolName'))]"
              },
              "probe": {
                "id": "[resourceId('Microsoft.Network/loadBalancers/probes', parameters('loadBalancerName'), parameters('probeName'))]"
              }
            }
          }
        ]
      }
    }
  ],
  "outputs": {
    "scenario": {
      "type": "string",
      "value": "day2-scenario03"
    },
    "deployedLoadBalancerName": {
      "type": "string",
      "value": "[parameters('loadBalancerName')]"
    },
    "deployedPublicIpAddress": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', parameters('publicIpName')), '2023-11-01').ipAddress]"
    }
  }
}
